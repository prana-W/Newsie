# Gemini API Key (required)
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# MongoDB source for embedding sync
MONGODB_URI=mongodb://localhost:27017/newsie
# Optional if DB name is already present in MONGODB_URI
MONGO_DB_NAME=newsie
MONGO_STORY_ARC_COLLECTION=story_arcs

# ChromaDB mode: cloud (Try Chroma) or local (PersistentClient)
CHROMA_MODE=cloud

# Cloud mode (Try Chroma)
# You can use host with or without scheme, e.g. https://api.trychroma.com or api.trychroma.com
CHROMA_HOST=your-chroma-cloud-host
CHROMA_PORT=443
CHROMA_SSL=true
CHROMA_API_KEY=your-chroma-api-key
CHROMA_TENANT=your-tenant
CHROMA_DATABASE=your-database

# Local mode (when CHROMA_MODE=local)
CHROMA_PERSIST_DIR=./.chroma

# Shared collection name
CHROMA_COLLECTION=story_arc_topics

# RAG Server Port
RAG_SERVER_PORT=8100
